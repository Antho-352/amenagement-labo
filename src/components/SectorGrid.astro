---
interface Sector {
  name: string;
  image: string;
  href?: string;
}

interface Props {
  sectors: Sector[];
}

const { sectors } = Astro.props;
---

<div class="grid grid-cols-2 md:grid-cols-4 gap-4 reveal-on-scroll">
  {sectors.map((sector) => (
    <a href={sector.href || '/secteurs-activite'} class="group relative h-64 overflow-hidden rounded-2xl block">
      <img src={sector.image} alt={sector.name} class="w-full h-full object-cover group-hover:scale-110 transition duration-700" loading="lazy" />
      <div class="absolute inset-0 bg-black/40 flex items-end p-6">
        <span class="text-white font-bold text-xl uppercase tracking-wider">{sector.name}</span>
      </div>
    </a>
  ))}
</div>
