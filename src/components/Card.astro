---
interface Props {
  title: string;
  description: string;
  icon?: string;
  link?: string;
  linkText?: string;
  variant?: 'default' | 'dark' | 'bordered';
  delay?: string;
}

const {
  title,
  description,
  link,
  linkText = 'En savoir plus',
  variant = 'default',
  delay,
} = Astro.props;

const baseClass = {
  default: 'p-10 border border-neutral-100 hover:shadow-xl transition-all group bg-white',
  dark: 'p-10 border border-white/10 hover:border-secondary transition-colors bg-white/5',
  bordered: 'p-8 border-t-2 border-secondary bg-neutral-50',
}[variant];
---

<article class={`${baseClass} reveal-on-scroll`} style={delay ? `transition-delay: ${delay}` : undefined}>
  <slot name="icon" />
  <h3 class={`text-2xl mb-4 ${variant === 'dark' ? 'text-secondary' : 'text-primary'}`}>{title}</h3>
  <p class={`mb-6 ${variant === 'dark' ? 'text-white/70 text-sm' : 'text-neutral-600'}`} set:html={description} />
  {link && (
    <a href={link} class="text-secondary font-bold flex items-center gap-2 hover:translate-x-2 transition-transform">
      {linkText}
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
    </a>
  )}
  <slot />
</article>
