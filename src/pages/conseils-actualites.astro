---
import BaseLayout from '../layouts/BaseLayout.astro';
import CtaBanner from '../components/CtaBanner.astro';
import { getPage, getPosts } from '../lib/wp';
import type { WpPost } from '../lib/types';

const schema = [
  { "@context": "https://schema.org", "@type": "Organization", "name": "amenagement-labo.fr", "url": "https://amenagement-labo.fr", "logo": "https://placehold.co/512x512/000/FFF?text=LOGO" },
  { "@context": "https://schema.org", "@type": "BreadcrumbList", "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://amenagement-labo.fr" },
    { "@type": "ListItem", "position": 2, "name": "Conseils & Actualités", "item": "https://amenagement-labo.fr/conseils-actualites" }
  ]}
];

let page;
try {
  page = await getPage('conseils-actualites');
} catch (e) {
  console.error('WP fetch failed for conseils-actualites:', e);
}

const seo = page?.seo;
const cta = page?.ctaFields;

let posts: WpPost[] = [];
try {
  posts = await getPosts(50);
} catch (e) {
  console.error('WP fetch failed for posts:', e);
}

function formatDate(dateStr: string) {
  return new Date(dateStr).toLocaleDateString('fr-FR', {
    day: 'numeric', month: 'long', year: 'numeric'
  }).toUpperCase();
}
---

<BaseLayout
  title={seo?.title ?? "Conseils & Actualités | Aménagement de Laboratoire 2026"}
  description={seo?.metaDesc ?? "Découvrez nos articles, conseils et actualités sur l'aménagement de laboratoires. Innovations, normes, bonnes pratiques."}
  keywords="aménagement laboratoire, conseils laboratoire, actualités laboratoire, normes laboratoire 2026"
  ogTitle={seo?.opengraphTitle ?? "Conseils & Actualités — amenagement-labo.fr"}
  ogDescription={seo?.opengraphDescription ?? "Articles et conseils d'experts pour l'aménagement de vos laboratoires."}
  ogImage={seo?.opengraphImage?.sourceUrl ?? "https://images.pexels.com/photos/9574561/pexels-photo-9574561.jpeg?auto=compress&cs=tinysrgb&dpr=2&h=650&w=940"}
  twitterTitle={seo?.twitterTitle ?? "Blog — amenagement-labo.fr"}
  twitterDescription={seo?.twitterDescription ?? "Conseils et actualités pour l'aménagement de laboratoires en 2026."}
  twitterImage={seo?.twitterImage?.sourceUrl ?? "https://images.pexels.com/photos/8325981/pexels-photo-8325981.jpeg?auto=compress&cs=tinysrgb&dpr=2&h=650&w=940"}
  canonical="https://amenagement-labo.fr/conseils-actualites"
  schema={schema}
>

  <!-- HEADER -->
  <section class="pt-32 pb-16 bg-bg-alt">
    <div class="container mx-auto px-6 text-center">
      <span class="inline-block px-6 py-2 border border-secondary text-secondary uppercase tracking-widest text-xs font-semibold mb-6">Blog & Conseils</span>
      <h1 class="text-5xl md:text-6xl font-heading text-primary mb-6">Le Magazine</h1>
      <p class="text-neutral-600 max-w-2xl mx-auto text-lg">Découvrez nos derniers articles, conseils d'experts et actualités pour optimiser vos espaces de laboratoire.</p>
    </div>
  </section>

  <!-- ARTICLES GRID -->
  <section class="py-16 bg-bg-alt">
    <div class="container mx-auto px-6">
      {posts.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {posts.map((post) => (
            <a href={`/blog/${post.slug}`} class="group relative block rounded-xl overflow-hidden aspect-[4/3] shadow-lg hover:shadow-2xl transition-shadow duration-300">
              {post.featuredImage?.node ? (
                <img
                  src={post.featuredImage.node.sourceUrl}
                  alt={post.featuredImage.node.altText || post.title}
                  class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
                  loading="lazy"
                />
              ) : (
                <div class="absolute inset-0 bg-primary"></div>
              )}
              <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-transparent"></div>
              <div class="absolute inset-0 p-6 flex flex-col justify-end">
                <div class="flex items-center gap-2 mb-3">
                  <span class="w-1 h-5 bg-secondary rounded-full"></span>
                  <span class="text-xs text-white/90 font-mono tracking-wider">{formatDate(post.date)}</span>
                </div>
                <h2 class="text-lg md:text-xl font-heading text-white font-bold leading-tight group-hover:text-secondary transition-colors duration-300" set:html={post.title} />
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div class="text-center py-20">
          <p class="text-neutral-500 text-lg">Les articles arrivent bientôt.</p>
        </div>
      )}
    </div>
  </section>

  <!-- CTA -->
  <CtaBanner
    title={cta?.ctaTitle ?? "Votre vision scientifique mérite une expertise d'exception"}
    description={cta?.ctaDescription ?? "Ensemble, concevons le laboratoire qui portera vos innovations de demain. Contactez nos experts pour un devis détaillé."}
    ctas={cta?.ctaButtons ?? [
      { label: 'Demander un devis', href: '/contact-devis' },
      { label: 'Nos réalisations', href: '/projets-realisations', variant: 'outline' },
    ]}
    bg={cta?.ctaBg ?? "white"}
  />

</BaseLayout>
