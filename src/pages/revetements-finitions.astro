<script>
  const surfaceRange = document.getElementById('surfaceRange') as HTMLInputElement;
  const surfaceVal = document.getElementById('surfaceVal');
  const solType = document.getElementById('solType') as HTMLSelectElement;
  const totalEstimate = document.getElementById('totalEstimate');
  const filters = document.getElementsByName('filter') as NodeListOf<HTMLInputElement>;

  function calculateEstimate() {
    const surface = parseInt(surfaceRange.value);
    const pricePerM2 = parseInt(solType.value);
    let filterPrice = 0;

    filters.forEach(f => {
      if (f.checked) filterPrice = parseInt(f.value);
    });

    const total = (surface * pricePerM2) + filterPrice + (surface * 150);

    if (surfaceVal) surfaceVal.innerText = surface + ' m²';
    if (totalEstimate) totalEstimate.innerText = new Intl.NumberFormat('fr-FR', { style: 'currency', currency: 'EUR', maximumFractionDigits: 0 }).format(total);
  }

  surfaceRange?.addEventListener('input', calculateEstimate);
  solType?.addEventListener('change', calculateEstimate);
  filters.forEach(f => f.addEventListener('change', calculateEstimate));
  calculateEstimate();
</script>
