<script>
  function calculateSetup() {
    const sizeEl = document.getElementById('labSize') as HTMLInputElement;
    const riskEl = document.getElementById('riskLevel') as HTMLSelectElement;
    const resultArea = document.getElementById('resultArea');
    if (!sizeEl || !riskEl || !resultArea) return;

    const size = sizeEl.value;
    const risk = riskEl.value;

    if (!size || parseInt(size) <= 0) {
      resultArea.innerHTML = "<span class='text-red-500'>Veuillez entrer une surface valide.</span>";
      return;
    }

    let recommendation = "";

    if (risk === "chimique") {
      recommendation = `Pour ${size}m² en risque chimique, nous préconisons : <br>• 1 Sorbonne NF EN 14175<br>• Paillasses en Grès étiré<br>• Armoire de sécurité pour Acides/Bases.`;
    } else if (risk === "inflammable") {
      recommendation = `Pour ${size}m² en risque solvants, nous préconisons : <br>• 1 Armoire de sécurité Type 90 (EN 14470-1)<br>• Système d'extraction ATEX<br>• Paillasses Trespa TopLab.`;
    } else if (risk === "bio") {
      recommendation = `Pour ${size}m² en risque bio, nous préconisons : <br>• Poste de Sécurité Microbiologique (PSM)<br>• Revêtements sols remontés en plinthes<br>• Paillasses en Résine Inox.`;
    } else {
      recommendation = `Pour ${size}m² en analyse classique, nous préconisons : <br>• Paillasses à piétement en H<br>• Mobilier de rangement suspendu<br>• Hotte d'aspiration localisée.`;
    }

    resultArea.classList.remove('italic', 'text-neutral-400');
    resultArea.classList.add('text-left', 'text-primary');
    resultArea.innerHTML = `<div>
      <h4 class='font-bold mb-4 uppercase text-xs tracking-widest text-secondary'>Préconisation 2026</h4>
      <p class='text-sm leading-relaxed'>${recommendation}</p>
      <a href='/contact-devis' class='mt-4 inline-block text-xs font-bold border-b border-primary'>Affiner ce devis &rarr;</a>
    </div>`;
  }

  document.getElementById('calcBtn')?.addEventListener('click', calculateSetup);
</script>
