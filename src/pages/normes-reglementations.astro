<script>
  const scoreEl = document.getElementById('audit-score');
  const feedbackEl = document.getElementById('audit-feedback');

  document.querySelectorAll('.audit-btn').forEach(btn => {
    btn.addEventListener('click', (e) => {
      const target = e.currentTarget as HTMLElement;
      const parent = target.parentElement;
      if (!parent) return;
      parent.querySelectorAll('button').forEach(b => {
        b.classList.remove('bg-primary', 'text-white');
      });
      target.classList.add('bg-primary', 'text-white');

      let total = 0;
      document.querySelectorAll('#audit-tool .bg-primary.text-white[data-points]').forEach(activeBtn => {
        total += parseInt((activeBtn as HTMLElement).dataset.points || '0');
      });

      const percent = Math.min(Math.round((total / 40) * 100), 100);

      if (scoreEl) scoreEl.innerText = percent + '%';

      if (feedbackEl) {
        if (percent < 40) feedbackEl.innerText = "Niveau de risque élevé. Une mise en conformité est urgente.";
        else if (percent < 80) feedbackEl.innerText = "Bonnes bases, mais des optimisations numériques sont nécessaires.";
        else feedbackEl.innerText = "Excellente conformité ! Vous êtes prêt pour les audits 2026.";
      }
    });
  });
</script>
