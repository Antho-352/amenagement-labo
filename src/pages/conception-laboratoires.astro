---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import FaqAccordion from '../components/FaqAccordion.astro';
import CtaBanner from '../components/CtaBanner.astro';
import { getPage } from '../lib/wp';

const schema = [
  { "@context": "https://schema.org", "@type": "Organization", "name": "amenagement-labo.fr", "url": "https://amenagement-labo.fr", "logo": "https://placehold.co/512x512/000/FFF?text=LOGO" },
  { "@context": "https://schema.org", "@type": "BreadcrumbList", "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://amenagement-labo.fr" },
    { "@type": "ListItem", "position": 2, "name": "Conception personnalisée de laboratoires", "item": "https://amenagement-labo.fr/conception-laboratoires" }
  ]}
];

let page;
try {
  page = await getPage('conception-laboratoires');
} catch (e) {
  console.error('WP fetch failed for conception-laboratoires:', e);
}

const seo = page?.seo;
const hero = page?.heroFields;
const faq = page?.faqFields;
const cta = page?.ctaFields;

const faqItems = faq?.faqItems ?? [
  { question: "Combien de temps prend la conception d'un laboratoire complet ?", answer: "La phase de conception (immersion, plans 3D, cahier des charges) dure généralement entre 4 et 8 semaines selon la complexité et la taille du projet." },
  { question: "Proposez-vous également la fourniture des équipements ?", answer: "Oui, nous offrons une solution clé en main incluant la <a href='/consommables-equipements' class='text-secondary font-semibold'>fourniture de consommables et équipements</a> : verrerie, instrumentation, et réactifs." },
  { question: "Intervenez-vous sur toute la France ?", answer: "Absolument. Nos équipes se déplacent partout en France pour assurer la conception et l'installation de vos aménagements de laboratoires." },
];
---

<BaseLayout
  title={seo?.title ?? "Conception personnalisée de laboratoires : Expertise Architecturale et Technique | amenagement-labo.fr"}
  description={seo?.metaDesc ?? "Découvrez notre approche de la conception de laboratoires en 2026. Alliez ergonomie de pointe et conformité normative pour vos espaces scientifiques et de recherche."}
  keywords="conception laboratoire, aménagement sur mesure, ergonomie laboratoire, design scientifique, modélisation 3D labo, normes laboratoire"
  ogTitle={seo?.opengraphTitle ?? "L'Art de Concevoir des Laboratoires : Fusion entre Science et Esthétique"}
  ogDescription={seo?.opengraphDescription ?? "Expertise complète en aménagement de laboratoires : de la modélisation 3D à l'installation technique. Créez un environnement performant et serein."}
  twitterTitle={seo?.twitterTitle ?? "Conception de Laboratoires Premium : L'Innovation par le Design"}
  twitterDescription={seo?.twitterDescription ?? "Transformez vos espaces de travail scientifiques. Design sur mesure, ergonomie et respect des normes 2026."}
  twitterImage={seo?.twitterImage?.sourceUrl ?? "https://images.pexels.com/photos/35589286/pexels-photo-35589286.jpeg?auto=compress&cs=tinysrgb&dpr=2&h=650&w=940"}
  schema={schema}
>

  <!-- HERO -->
  <Hero
    title={hero?.heroTitle ?? "Concevoir le <span class='text-secondary'>Futur</span> de la Recherche Scientifique"}
    subtitle={hero?.heroSubtitle ?? "En 2026, l'aménagement de laboratoire transcende la simple fonctionnalité. Nous créons des écosystèmes où la précision technique rencontre l'élégance du design pour catalyser l'innovation."}
    bgImage={hero?.heroImage?.url ?? "https://images.pexels.com/photos/9574561/pexels-photo-9574561.jpeg?auto=compress&cs=tinysrgb&dpr=2&h=650&w=940"}
    bgAlt="Laboratoire moderne"
    badge={hero?.heroBadge ?? "L'Excellence Architecturale"}
    height="h-screen"
    ctas={hero?.heroCtas ?? [
      { label: 'Démarrer votre projet', href: '/contact-devis' },
      { label: 'Voir nos réalisations', href: '/projets-realisations', variant: 'outline' },
    ]}
  />

  <!-- INTRODUCTION DÉTAILLÉE -->
  <section class="py-24 bg-bg-alt">
    <div class="container mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div class="reveal-on-scroll">
          <h2 class="text-4xl md:text-5xl text-primary mb-8">L'harmonie entre rigueur scientifique et bien-être</h2>
          <div class="space-y-6 text-lg text-neutral-700">
            <p>
              La conception d'un laboratoire moderne ne se limite plus à l'alignement de paillasses et à l'installation de sorbonnes. Aujourd'hui, les décideurs du secteur de la santé, de la pharma et de la recherche exigent des espaces qui reflètent leur niveau d'expertise tout en offrant un environnement stimulant pour leurs équipes.
            </p>
            <p>
              Chez <strong>amenagement-labo.fr</strong>, notre philosophie repose sur l'équilibre. Un équilibre fragile mais essentiel entre les contraintes normatives strictes et une esthétique soignée. Nous croyons que la beauté d'un espace de travail influence directement la qualité des résultats et la rétention des talents.
            </p>
            <p>
              Que vous planifiiez une <a href="/" class="text-secondary underline decoration-1 underline-offset-4 hover:text-primary">conception complète de laboratoire</a> ou une rénovation partielle, notre approche intègre chaque détail : de la réflectivité des sols à l'acoustique des zones de traitement, pour transformer votre outil de travail en un actif stratégique.
            </p>
          </div>
        </div>
        <div class="relative reveal-on-scroll">
          <div class="aspect-square rounded-2xl overflow-hidden border-8 border-white shadow-2xl">
            <img src="https://images.pexels.com/photos/196644/pexels-photo-196644.jpeg?auto=compress&cs=tinysrgb&dpr=2&h=650&w=940" alt="Design de laboratoire" class="w-full h-full object-cover" loading="lazy" />
          </div>
          <div class="absolute -bottom-10 -left-10 bg-secondary p-8 hidden md:block">
            <p class="text-primary font-heading text-3xl italic">"Le design est l'ambassadeur silencieux de votre excellence scientifique."</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- PROCESSUS DE CO-CONSTRUCTION -->
  <section class="py-24 bg-white">
    <div class="container mx-auto px-6">
      <div class="text-center mb-20 reveal-on-scroll">
        <h2 class="text-4xl md:text-5xl text-primary mb-4">Un processus de co-construction</h2>
        <div class="w-24 h-1 bg-secondary mx-auto"></div>
        <p class="mt-8 text-xl text-neutral-600 max-w-3xl mx-auto">
          Nous ne concevons pas <em>pour</em> vous, mais <em>avec</em> vous. L'implication des utilisateurs finaux est la clé d'un projet réussi.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
        <div class="p-8 border-t-2 border-secondary bg-neutral-50 reveal-on-scroll" style="transition-delay: 100ms;">
          <span class="text-6xl font-heading text-secondary/30 mb-4 block">01</span>
          <h3 class="text-2xl font-bold text-primary mb-4">Immersion &amp; analyse des flux</h3>
          <p class="text-neutral-600 mb-6">
            Nous analysons vos processus quotidiens, le taux d'affluence des patients et les mouvements du personnel pour identifier les goulots d'étranglement. Cette étape définit l'ADN de votre futur laboratoire.
          </p>
          <ul class="space-y-2 text-sm text-primary">
            <li>• Étude des flux logistiques</li>
            <li>• Interviews du personnel technique</li>
            <li>• Audit de l'existant</li>
          </ul>
        </div>
        <div class="p-8 border-t-2 border-secondary bg-neutral-50 reveal-on-scroll" style="transition-delay: 200ms;">
          <span class="text-6xl font-heading text-secondary/30 mb-4 block">02</span>
          <h3 class="text-2xl font-bold text-primary mb-4">Modélisation 3D interactive</h3>
          <p class="text-neutral-600 mb-6">
            Grâce à nos outils de pointe, vous visualisez votre laboratoire avant même le premier coup de pioche. La 3D permet d'ajuster l'ergonomie des postes de travail en temps réel.
          </p>
          <ul class="space-y-2 text-sm text-primary">
            <li>• Rendu photoréaliste</li>
            <li>• Simulation d'éclairage naturel</li>
            <li>• Validation des circulations</li>
          </ul>
        </div>
        <div class="p-8 border-t-2 border-secondary bg-neutral-50 reveal-on-scroll" style="transition-delay: 300ms;">
          <span class="text-6xl font-heading text-secondary/30 mb-4 block">03</span>
          <h3 class="text-2xl font-bold text-primary mb-4">Ingénierie de détail</h3>
          <p class="text-neutral-600 mb-6">
            C'est ici que la technique prend vie. Nous planifions l'intégration des <a href="/installation-equipements-techniques" class="text-secondary font-semibold">équipements techniques</a>, des réseaux de fluides et de l'électricité.
          </p>
          <ul class="space-y-2 text-sm text-primary">
            <li>• Plans de réservations électriques</li>
            <li>• Dimensionnement de l'extraction</li>
            <li>• Choix des matériaux HT</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ERGONOMIE & BIEN-ÊTRE -->
  <section class="py-24 bg-primary text-white">
    <div class="container mx-auto px-6">
      <div class="flex flex-wrap -mx-6">
        <div class="w-full lg:w-1/2 px-6 mb-12 lg:mb-0 reveal-on-scroll">
          <img src="https://images.pexels.com/photos/668300/pexels-photo-668300.jpeg?auto=compress&cs=tinysrgb&dpr=2&h=650&w=940" alt="Environnement de travail optimisé" class="rounded-3xl shadow-2xl" loading="lazy" />
        </div>
        <div class="w-full lg:w-1/2 px-6 flex flex-col justify-center reveal-on-scroll">
          <h2 class="text-4xl md:text-5xl mb-8">L'ergonomie au service de la performance</h2>
          <p class="text-xl text-neutral-300 mb-8">
            Un laboratoire bien conçu réduit la fatigue, limite les erreurs et améliore la concentration de vos équipes. L'ergonomie est un investissement qui se mesure au quotidien.
          </p>
          <div class="space-y-8">
            <div class="flex gap-4">
              <div class="w-12 h-12 shrink-0 bg-secondary flex items-center justify-center rounded-full">
                <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              </div>
              <div>
                <h4 class="text-xl font-bold mb-2">Postes de travail adaptés</h4>
                <p class="text-neutral-400">Hauteurs réglables, éclairage ciblé et agencement pensé pour les gestes répétitifs du quotidien.</p>
              </div>
            </div>
            <div class="flex gap-4">
              <div class="w-12 h-12 shrink-0 bg-secondary flex items-center justify-center rounded-full">
                <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
              </div>
              <div>
                <h4 class="text-xl font-bold mb-2">Circulation optimisée</h4>
                <p class="text-neutral-400">Des flux logiques qui minimisent les déplacements inutiles et réduisent les risques de contamination croisée.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SIMULATEUR D'AGENCEMENT -->
  <section class="py-24 bg-white">
    <div class="container mx-auto px-6">
      <div class="max-w-4xl mx-auto bg-white/95 backdrop-blur-sm p-12 rounded-3xl shadow-xl border-2 border-secondary/20">
        <div class="text-center mb-10">
          <h3 class="text-3xl text-primary mb-4">Simulateur d'optimisation d'espace</h3>
          <p class="text-neutral-600">Estimez la configuration idéale de votre futur plateau technique en quelques clics.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
          <div class="space-y-6">
            <div>
              <label class="block text-sm font-bold text-primary mb-2">Surface disponible (m²)</label>
              <input type="range" id="surfaceRange" min="50" max="1000" value="150" class="w-full h-2 bg-neutral-200 rounded-lg appearance-none cursor-pointer accent-secondary" />
              <span id="surfaceVal" class="text-lg font-bold text-secondary">150 m²</span>
            </div>
            <div>
              <label class="block text-sm font-bold text-primary mb-2">Nombre de techniciens</label>
              <input type="number" id="staffInput" value="5" class="w-full p-3 border border-neutral-300 rounded focus:border-secondary focus:outline-none" />
            </div>
            <div>
              <label class="block text-sm font-bold text-primary mb-2">Secteur d'activité</label>
              <select id="sectorInput" class="w-full p-3 border border-neutral-300 rounded focus:border-secondary focus:outline-none">
                <option value="medical">Biologie Médicale</option>
                <option value="dental">Contrôle qualité</option>
                <option value="pharma">Pharmaceutique / Chimie</option>
                <option value="food">Agroalimentaire</option>
              </select>
            </div>
          </div>

          <div class="bg-primary p-8 rounded-2xl text-white">
            <h4 class="text-lg font-bold mb-6 text-secondary">Nos recommandations :</h4>
            <div id="results" class="space-y-4">
              <p class="flex justify-between border-b border-white/10 pb-2"><span>Espace technique :</span> <span class="font-bold">85 m²</span></p>
              <p class="flex justify-between border-b border-white/10 pb-2"><span>Nombre de paillasses :</span> <span class="font-bold">12</span></p>
              <p class="flex justify-between border-b border-white/10 pb-2"><span>Zones de stockage :</span> <span class="font-bold">20 m²</span></p>
              <p class="mt-6 text-sm italic opacity-80">* Ces valeurs sont indicatives. Une étude personnalisée est nécessaire.</p>
            </div>
            <a href="/contact-devis" class="block w-full mt-8 py-3 bg-secondary text-primary font-bold rounded hover:bg-white transition-colors text-center">Recevoir un plan détaillé</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- LABORATOIRES SCIENTIFIQUES -->
  <section class="py-24 bg-neutral-50 overflow-hidden">
    <div class="container mx-auto px-6">
      <div class="flex flex-wrap items-center">
        <div class="w-full lg:w-1/2 mb-12 lg:mb-0 reveal-on-scroll">
          <h2 class="text-4xl md:text-5xl text-primary mb-8">Des espaces pensés pour la recherche et le contrôle qualité</h2>
          <p class="text-lg text-neutral-700 mb-6">
            Qu'il s'agisse d'un laboratoire de R&D, d'une unité de contrôle qualité ou d'un espace d'analyse, chaque projet présente des contraintes spécifiques. Nous concevons des postes de travail modulaires qui s'adaptent aux activités de vos équipes, favorisant la productivité et prévenant les troubles musculo-squelettiques (TMS).
          </p>
          <p class="text-lg text-neutral-700 mb-8">
            Nos solutions intègrent la gestion des flux de circulation, l'optimisation de l'éclairage, le positionnement des équipements critiques et l'accessibilité des postes de travail. Chaque détail est étudié pour garantir un environnement fonctionnel, sûr et agréable.
          </p>
          <div class="grid grid-cols-2 gap-4">
            <div class="p-4 bg-white shadow-sm border-l-4 border-secondary">
              <p class="font-bold text-primary">Modularité totale</p>
              <p class="text-sm text-neutral-500">Mobilier évolutif selon vos besoins.</p>
            </div>
            <div class="p-4 bg-white shadow-sm border-l-4 border-secondary">
              <p class="font-bold text-primary">Ventilation intégrée</p>
              <p class="text-sm text-neutral-500">Qualité de l'air et confort garantis.</p>
            </div>
          </div>
        </div>
        <div class="w-full lg:w-1/2 lg:pl-20 reveal-on-scroll">
          <div class="relative">
            <img src="https://images.pexels.com/photos/8657297/pexels-photo-8657297.jpeg?auto=compress&cs=tinysrgb&dpr=2&h=650&w=940" alt="Laboratoire scientifique moderne" class="rounded-full w-full aspect-square object-cover border-[20px] border-white shadow-xl" loading="lazy" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- RÉNOVATION EN SITE OCCUPÉ -->
  <section class="py-24 bg-white">
    <div class="container mx-auto px-6">
      <div class="bg-primary rounded-[3rem] p-12 md:p-20 text-white relative overflow-hidden">
        <div class="relative z-10 grid grid-cols-1 lg:grid-cols-2 gap-16">
          <div>
            <h2 class="text-4xl md:text-5xl mb-8">Rénovation en site occupé : Le défi de la continuité</h2>
            <p class="text-xl text-neutral-300 mb-8 leading-relaxed">
              Nous savons que votre activité ne peut s'arrêter. Nos experts en gestion de projet planifient chaque phase de travaux pour garantir une sécurité maximale et une perturbation minimale.
            </p>
            <div class="space-y-4">
              <div class="flex items-start gap-4">
                <span class="text-secondary text-2xl">&#10004;</span>
                <p>Organisation des phases de travaux en concertation avec vos équipes pour limiter les perturbations.</p>
              </div>
              <div class="flex items-start gap-4">
                <span class="text-secondary text-2xl">&#10004;</span>
                <p>Planning adapté à vos contraintes opérationnelles, défini en amont avec votre chef de projet.</p>
              </div>
              <div class="flex items-start gap-4">
                <span class="text-secondary text-2xl">&#10004;</span>
                <p>Respect strict des <a href="/normes-reglementations" class="text-secondary underline">normes de sécurité</a> 2026.</p>
              </div>
            </div>
          </div>
          <div class="bg-white/5 p-8 rounded-2xl border border-white/10">
            <h3 class="text-2xl font-heading text-secondary mb-6">Nos engagements clés</h3>
            <ul class="space-y-6">
              <li class="flex justify-between items-center">
                <span>Prix contractuel ferme</span>
                <span class="h-[1px] flex-grow mx-4 bg-white/20"></span>
                <span class="font-bold">100%</span>
              </li>
              <li class="flex justify-between items-center">
                <span>Respect des délais</span>
                <span class="h-[1px] flex-grow mx-4 bg-white/20"></span>
                <span class="font-bold">Garanti</span>
              </li>
              <li class="flex justify-between items-center">
                <span>Interlocuteur unique</span>
                <span class="h-[1px] flex-grow mx-4 bg-white/20"></span>
                <span class="font-bold">Chef de Projet Dédié</span>
              </li>
            </ul>
            <div class="mt-12">
              <img src="https://images.pexels.com/photos/35300832/pexels-photo-35300832.jpeg?auto=compress&cs=tinysrgb&dpr=2&h=650&w=940" alt="Travaux sécurisés" class="rounded-xl opacity-80 grayscale hover:grayscale-0 transition-all" loading="lazy" />
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- MATÉRIAUX ET FINITIONS -->
  <section class="py-24 bg-white">
    <div class="container mx-auto px-6">
      <div class="text-center mb-20 reveal-on-scroll">
        <h2 class="text-4xl md:text-5xl text-primary mb-4">La noblesse des matériaux</h2>
        <p class="text-xl text-neutral-600">Pour un laboratoire durable, chaque surface compte.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
        <div class="group cursor-pointer reveal-on-scroll">
          <div class="aspect-video mb-6 overflow-hidden rounded-lg">
            <img src="https://images.pexels.com/photos/33013263/pexels-photo-33013263.jpeg?auto=compress&cs=tinysrgb&dpr=2&h=650&w=940" alt="Verre technique" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" loading="lazy" />
          </div>
          <h4 class="text-xl font-bold text-primary mb-2">Verre et transparence</h4>
          <p class="text-neutral-600 text-sm">Utilisation de cloisons vitrées pour favoriser la lumière naturelle et la communication visuelle.</p>
        </div>
        <div class="group cursor-pointer reveal-on-scroll" style="transition-delay: 100ms;">
          <div class="aspect-video mb-6 overflow-hidden rounded-lg">
            <img src="https://images.pexels.com/photos/29842696/pexels-photo-29842696.jpeg?auto=compress&cs=tinysrgb&dpr=2&h=650&w=940" alt="Inox médical" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" loading="lazy" />
          </div>
          <h4 class="text-xl font-bold text-primary mb-2">Inox et résines</h4>
          <p class="text-neutral-600 text-sm">Surfaces décontaminables aux ions d'argent pour une hygiène irréprochable.</p>
        </div>
        <div class="group cursor-pointer reveal-on-scroll" style="transition-delay: 200ms;">
          <div class="aspect-video mb-6 overflow-hidden rounded-lg">
            <img src="https://images.pexels.com/photos/6254/texture-broken-vintage-wooden.jpg?auto=compress&cs=tinysrgb&dpr=2&h=650&w=940" alt="Bois chaleureux" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" loading="lazy" />
          </div>
          <h4 class="text-xl font-bold text-primary mb-2">Bois et chaleur</h4>
          <p class="text-neutral-600 text-sm">Accents boisés dans les zones administratives pour humaniser l'environnement technique.</p>
        </div>
        <div class="group cursor-pointer reveal-on-scroll" style="transition-delay: 300ms;">
          <div class="aspect-video mb-6 overflow-hidden rounded-lg">
            <img src="https://images.pexels.com/photos/368754/pexels-photo-368754.jpeg?auto=compress&cs=tinysrgb&dpr=2&h=650&w=940" alt="Sol technique" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" loading="lazy" />
          </div>
          <h4 class="text-xl font-bold text-primary mb-2">Sols performants</h4>
          <p class="text-neutral-600 text-sm">Consultez nos <a href="/revetements-finitions" class="text-secondary underline">revêtements et finitions</a> techniques pour sols antistatiques.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <FaqAccordion items={faqItems} title="Questions fréquentes" />

  <!-- CTA FINAL -->
  <CtaBanner
    title={cta?.ctaTitle ?? "Prêt à transformer votre laboratoire ?"}
    description={cta?.ctaDescription ?? "Confiez votre projet à des experts qui comprennent vos enjeux scientifiques et esthétiques. Obtenez une étude personnalisée dès aujourd'hui."}
    ctas={cta?.ctaButtons ?? [
      { label: 'Demander mon devis gratuit', href: '/contact-devis' },
    ]}
    bg={cta?.ctaBg ?? "gold"}
  />

</BaseLayout>

<script>
  const surfaceRange = document.getElementById('surfaceRange') as HTMLInputElement;
  const surfaceVal = document.getElementById('surfaceVal');
  const staffInput = document.getElementById('staffInput') as HTMLInputElement;
  const sectorInput = document.getElementById('sectorInput') as HTMLSelectElement;
  const resultsDiv = document.getElementById('results');

  function updateSimulation() {
    const surf = parseInt(surfaceRange.value);
    const staff = parseInt(staffInput.value);
    const sector = sectorInput.value;

    if (surfaceVal) surfaceVal.innerText = surf + ' m²';

    let techRatio = sector === 'dental' ? 0.7 : 0.6;
    let benchCount = Math.floor((surf * techRatio) / 7.5);
    let storage = Math.floor(surf * 0.15);
    let techSpace = Math.floor(surf * techRatio);

    if (resultsDiv) {
      resultsDiv.innerHTML = `
        <p class="flex justify-between border-b border-white/10 pb-2"><span>Espace technique :</span> <span class="font-bold">${techSpace} m²</span></p>
        <p class="flex justify-between border-b border-white/10 pb-2"><span>Postes de travail :</span> <span class="font-bold">${benchCount}</span></p>
        <p class="flex justify-between border-b border-white/10 pb-2"><span>Zones de stockage :</span> <span class="font-bold">${storage} m²</span></p>
        <p class="mt-6 text-sm italic opacity-80">* Calcul basé sur les normes d'ergonomie 2026 pour le secteur ${sector}.</p>
      `;
    }
  }

  surfaceRange?.addEventListener('input', updateSimulation);
  staffInput?.addEventListener('input', updateSimulation);
  sectorInput?.addEventListener('change', updateSimulation);
  updateSimulation();
</script>
