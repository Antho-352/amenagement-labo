---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import FaqAccordion from '../components/FaqAccordion.astro';
import CtaBanner from '../components/CtaBanner.astro';
import { getPage } from '../lib/wp';

const schema = [
  { "@context": "https://schema.org", "@type": "Organization", "name": "amenagement-labo.fr", "url": "https://amenagement-labo.fr", "logo": "https://placehold.co/512x512/000/FFF?text=LOGO" },
  { "@context": "https://schema.org", "@type": "BreadcrumbList", "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://amenagement-labo.fr" },
    { "@type": "ListItem", "position": 2, "name": "Fourniture complète de consommables et équipements", "item": "https://amenagement-labo.fr/consommables-equipements" }
  ]}
];

let page;
try {
  page = await getPage('consommables-equipements');
} catch (e) {
  console.error('WP fetch failed for consommables-equipements:', e);
}

const seo = page?.seo;
const faq = page?.faqFields;
const cta = page?.ctaFields;

const faqItems = faq?.faqItems ?? [
  { question: "Quels sont vos délais pour les produits chimiques hors stock ?", answer: "Grâce à notre réseau de fournisseurs européens, nous sommes capables d'approvisionner des réactifs spécifiques sous 5 à 7 jours ouvrés en moyenne." },
  { question: "Assurez-vous la qualification des équipements (IQ/OQ/PQ) ?", answer: "Oui, pour l'instrumentation critique (autoclaves, balances, étuves), notre service technique propose des protocoles de qualification complets conformes aux normes BPL/BPF." },
];
---

<BaseLayout
  title={seo?.title ?? "Fourniture de consommables & équipements de laboratoire | amenagement-labo.fr"}
  description={seo?.metaDesc ?? "Fourniture complète de consommables et équipements pour laboratoires : verrerie standard, instrumentation de précision, produits chimiques et petit matériel. Un interlocuteur unique pour simplifier votre approvisionnement."}
  keywords="verrerie laboratoire, matériel scientifique, instrumentation analyse, produits chimiques, équipement laboratoire France, consommables scientifiques"
  ogTitle={seo?.opengraphTitle ?? "Consommables et équipements de laboratoire — amenagement-labo.fr"}
  ogDescription={seo?.opengraphDescription ?? "Verrerie, instrumentation, réactifs et consommables pour laboratoires exigeants. Un catalogue complet et un interlocuteur unique."}
  twitterTitle={seo?.twitterTitle ?? "Consommables et équipements de laboratoire — amenagement-labo.fr"}
  twitterDescription={seo?.twitterDescription ?? "Fourniture complète de consommables, verrerie et instrumentation pour tous secteurs scientifiques."}
  twitterImage={seo?.twitterImage?.sourceUrl ?? "https://images.pexels.com/photos/1148450/pexels-photo-1148450.jpeg?auto=compress&cs=tinysrgb&dpr=2&h=650&w=940"}
  schema={schema}
>

  <!-- HERO -->
  <section class="relative min-h-[90vh] flex items-center pt-20 overflow-hidden bg-bg-alt">
    <div class="container mx-auto px-6 grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
      <div class="lg:col-span-7 z-10">
        <span class="inline-block px-4 py-1 border border-secondary text-secondary text-sm uppercase tracking-widest mb-6 font-medium">Approvisionnement laboratoire</span>
        <h1 class="font-heading text-6xl lg:text-8xl leading-tight text-primary mb-8 reveal-on-scroll">
          Consommables & <br> <span class="italic text-secondary">équipements</span> de laboratoire
        </h1>
        <p class="text-xl text-neutral-600 mb-10 max-w-2xl leading-relaxed reveal-on-scroll">
          Nous assurons la fourniture de consommables et d'équipements courants pour vos laboratoires : verrerie standard, petits équipements, consommables analytiques et produits de protection. Notre rôle est de vous simplifier l'approvisionnement en vous proposant un interlocuteur unique, de la commande à la livraison.
        </p>
        <div class="flex flex-wrap gap-4 reveal-on-scroll">
          <a href="/contact-devis" class="px-8 py-4 bg-primary text-white hover:bg-primary/90 transition-all duration-300 font-medium tracking-wide">Demander un devis</a>
          <a href="/projets-realisations" class="px-8 py-4 border border-primary text-primary hover:bg-white transition-all duration-300 font-medium">Nos références</a>
        </div>
      </div>
      <div class="lg:col-span-5 relative">
        <div class="relative w-full aspect-[4/5] rounded-t-full overflow-hidden border-[12px] border-white shadow-2xl">
          <img src="https://images.pexels.com/photos/8657297/pexels-photo-8657297.jpeg?auto=compress&cs=tinysrgb&dpr=2&h=650&w=940" alt="Équipements et consommables de laboratoire" class="w-full h-full object-cover" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- NOTRE APPROCHE -->
  <section class="py-24 bg-white border-b border-neutral-100">
    <div class="container mx-auto px-6">
      <div class="flex flex-col md:flex-row gap-16 items-start">
        <div class="md:w-1/3 sticky top-24">
          <h2 class="font-heading text-4xl text-primary mb-6 reveal-on-scroll">Un interlocuteur unique pour votre laboratoire.</h2>
          <div class="w-20 h-1 bg-secondary mb-8"></div>
          <p class="text-neutral-500 italic mb-4">"Simplifier l'approvisionnement pour que vous puissiez vous concentrer sur l'essentiel : vos recherches."</p>
        </div>
        <div class="md:w-2/3 space-y-8 text-lg text-neutral-700 leading-loose reveal-on-scroll">
          <p>
            L'approvisionnement d'un laboratoire est un travail de précision. Chaque référence, chaque délai, chaque certificat de conformité compte. En centralisant vos commandes auprès d'un partenaire unique, vous gagnez en réactivité, en traçabilité et en simplicité administrative.
          </p>
          <p>
            Notre catalogue couvre l'ensemble des besoins courants : verrerie standard (béchers, ballons, éprouvettes), consommables analytiques (filtres, pipettes, embouts), produits chimiques de haute pureté et équipements de protection individuelle. Nous travaillons avec les grands fabricants du secteur pour vous garantir des produits conformes et disponibles.
          </p>
          <p>
            En complément de notre activité d'<a href="/" class="text-secondary underline decoration-1 underline-offset-4 font-medium">aménagement de laboratoire</a>, ce service de fourniture vous permet de bénéficier d'un accompagnement global, de la <a href="/installation-equipements-techniques" class="text-secondary underline">pose de paillasses</a> à la livraison de vos consommables récurrents.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- LES 5 PILIERS DE L'OFFRE -->
  <section class="py-24 bg-primary text-white">
    <div class="container mx-auto px-6">
      <div class="text-center mb-20 reveal-on-scroll">
        <h2 class="font-heading text-5xl mb-6">Notre écosystème de fourniture</h2>
        <p class="text-secondary uppercase tracking-widest text-sm">Une gamme exhaustive pour toutes vos manipulations</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="p-10 border border-white/10 hover:border-secondary transition-colors duration-500 bg-white/5 backdrop-blur-sm group">
          <div class="w-12 h-12 mb-8 flex items-center justify-center border border-secondary text-secondary group-hover:bg-secondary group-hover:text-primary transition-all">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.423 15.483a4.42 4.42 0 00.75-2.232c.15-1.125-.135-2.277-.81-3.23l-3.322-4.665a.45.45 0 00-.734.001L11.5 10.602l-2.096-2.94a.45.45 0 00-.734.001l-3.19 4.478a4.423 4.423 0 00-.81 3.23c.15 1.125.75 2.121 1.635 2.808a4.423 4.423 0 003.543.832c1.125-.15 2.121-.75 2.808-1.635l2.096-2.94 2.096 2.94a4.421 4.421 0 002.808 1.635 4.423 4.423 0 003.543-.832z"></path></svg>
          </div>
          <h3 class="font-heading text-2xl mb-4 italic text-secondary">Verrerie scientifique</h3>
          <p class="text-white/70 text-sm leading-relaxed mb-6">Béchers, ballons, éprouvettes et verrerie standard en borosilicate 3.3 pour toutes vos applications analytiques et préparatoires.</p>
          <ul class="text-xs space-y-2 text-white/50">
            <li>• Rodages normalisés (ST)</li>
            <li>• Verrerie graduée et volumétrique</li>
            <li>• Borosilicate, quartz et verres spéciaux</li>
          </ul>
        </div>

        <div class="p-10 border border-white/10 hover:border-secondary transition-colors duration-500 bg-white/5 backdrop-blur-sm group">
          <div class="w-12 h-12 mb-8 flex items-center justify-center border border-secondary text-secondary group-hover:bg-secondary group-hover:text-primary transition-all">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path></svg>
          </div>
          <h3 class="font-heading text-2xl mb-4 italic text-secondary">Instrumentation d'analyse</h3>
          <p class="text-white/70 text-sm leading-relaxed mb-6">Appareils de mesure haute précision : spectrométrie, chromatographie, microscopie et agitation.</p>
          <ul class="text-xs space-y-2 text-white/50">
            <li>• Spectrophotomètres UV-Vis</li>
            <li>• Balances analytiques (0.1mg)</li>
            <li>• Agitateurs magnétiques chauffants</li>
          </ul>
        </div>

        <div class="p-10 border border-white/10 hover:border-secondary transition-colors duration-500 bg-white/5 backdrop-blur-sm group">
          <div class="w-12 h-12 mb-8 flex items-center justify-center border border-secondary text-secondary group-hover:bg-secondary group-hover:text-primary transition-all">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.423 4.5h-2.846a4.5 4.5 0 00-8.577 0H5.154a2.25 2.25 0 00-2.25 2.25v13.5A2.25 2.25 0 005.154 22.5h13.692a2.25 2.25 0 002.25-2.25V6.75a2.25 2.25 0 00-2.25-2.25z"></path></svg>
          </div>
          <h3 class="font-heading text-2xl mb-4 italic text-secondary">Usage unique & hygiène</h3>
          <p class="text-white/70 text-sm leading-relaxed mb-6">Stock massif de produits de filtration, gants, pipettes et embouts pour un flux continu de travail.</p>
          <ul class="text-xs space-y-2 text-white/50">
            <li>• Filtration membranaire et seringues</li>
            <li>• EPI : Gants nitrile, lunettes, masques</li>
            <li>• Micropipettes et pointes certifiées</li>
          </ul>
        </div>

        <div class="p-10 border border-white/10 hover:border-secondary transition-colors duration-500 bg-white/5 backdrop-blur-sm group">
          <div class="w-12 h-12 mb-8 flex items-center justify-center border border-secondary text-secondary group-hover:bg-secondary group-hover:text-primary transition-all">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11.25 11.25l.041-.02a.75.75 0 011.063.852l-.708 2.836a.75.75 0 001.063.853l.041-.021M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9-3.75h.008v.008H12V8.25z"></path></svg>
          </div>
          <h3 class="font-heading text-2xl mb-4 italic text-secondary">Réactifs & chimie</h3>
          <p class="text-white/70 text-sm leading-relaxed mb-6">Pureté analytique garantie pour vos solvants, acides, bases et étalons. Gestion stricte des stocks.</p>
          <ul class="text-xs space-y-2 text-white/50">
            <li>• Solvants HPLC / Gradient</li>
            <li>• Produits chimiques de synthèse</li>
            <li>• Milieux de culture microbiologie</li>
          </ul>
        </div>

        <div class="p-10 border border-white/10 hover:border-secondary transition-colors duration-500 bg-white/5 backdrop-blur-sm group">
          <div class="w-12 h-12 mb-8 flex items-center justify-center border border-secondary text-secondary group-hover:bg-secondary group-hover:text-primary transition-all">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-.778.099-1.533.284-2.253"></path></svg>
          </div>
          <h3 class="font-heading text-2xl mb-4 italic text-secondary">Appareillage technique</h3>
          <p class="text-white/70 text-sm leading-relaxed mb-6">Intégration d'unités autonomes : centrifugeuses, autoclaves, étuves et enceintes climatiques.</p>
          <ul class="text-xs space-y-2 text-white/50">
            <li>• Étuves à convection forcée</li>
            <li>• Systèmes de purification d'eau</li>
            <li>• Stockage ultra-basse température</li>
          </ul>
        </div>

        <div class="p-10 border border-white/10 hover:border-secondary transition-colors duration-500 bg-white/5 backdrop-blur-sm group">
          <div class="w-12 h-12 mb-8 flex items-center justify-center border border-secondary text-secondary group-hover:bg-secondary group-hover:text-primary transition-all">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>
          </div>
          <h3 class="font-heading text-2xl mb-4 italic text-secondary">Accompagnement expert</h3>
          <p class="text-white/70 text-sm leading-relaxed mb-6">Plus qu'une vente, nous offrons une Hotline technique et un SAV dédié sur site pour la maintenance.</p>
          <ul class="text-xs space-y-2 text-white/50">
            <li>• Installation et mise en service</li>
            <li>• Métrologie et étalonnage COFRAC</li>
            <li>• Audit de sécurité chimique</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- CALCULATEUR DE DOTATION INITIALE -->
  <section class="py-24 bg-white overflow-hidden">
    <div class="container mx-auto px-6">
      <div class="bg-bg-alt p-12 lg:p-20 shadow-xl border border-neutral-100 relative">
        <div class="absolute top-0 right-0 w-32 h-32 bg-secondary/10 -translate-y-1/2 translate-x-1/2 rotate-45"></div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
          <div>
            <h2 class="font-heading text-4xl text-primary mb-6 reveal-on-scroll">Estimez votre pack de démarrage</h2>
            <p class="text-neutral-600 mb-8">
              Vous lancez une nouvelle unité de recherche ou une startup en <a href="/secteurs-activite" class="text-primary font-semibold">cosmétique</a> ? Utilisez notre simulateur pour évaluer vos besoins essentiels en consommables de base.
            </p>

            <div class="space-y-6">
              <label class="block">
                <span class="text-sm font-semibold uppercase text-primary">Type de laboratoire</span>
                <select id="lab-type" class="mt-2 block w-full border-neutral-200 bg-white px-4 py-3 focus:border-secondary focus:ring-0 transition-all">
                  <option value="chimie">Chimie Organique / Synthèse</option>
                  <option value="bio">Microbiologie / Biochimie</option>
                  <option value="physique">Analyse Physique / Matériaux</option>
                  <option value="enseig">Enseignement / Éducation</option>
                </select>
              </label>

              <label class="block">
                <span class="text-sm font-semibold uppercase text-primary">Nombre de paillasses</span>
                <input type="range" id="bench-count" min="1" max="20" value="4" class="w-full mt-4 accent-primary" />
                <div class="flex justify-between text-xs text-neutral-400 mt-2">
                  <span>1 paillasse</span>
                  <span id="bench-val" class="font-bold text-secondary">4 paillasses</span>
                  <span>20 paillasses</span>
                </div>
              </label>

              <button id="calc-btn" class="w-full py-4 bg-gradient-to-r from-secondary to-secondary/80 text-white font-bold tracking-widest uppercase text-sm hover:opacity-90 transition-opacity">Générer la liste prévisionnelle</button>
            </div>
          </div>

          <div id="result-box" class="bg-white border border-secondary/30 p-8 rounded-sm min-h-[400px]">
            <div class="flex items-center gap-4 mb-6 border-b border-neutral-100 pb-4">
              <div class="w-3 h-3 rounded-full bg-secondary"></div>
              <h3 class="text-lg font-medium text-primary">Recommandations</h3>
            </div>
            <div id="results-content" class="text-sm text-neutral-600 space-y-4">
              <p class="italic text-center py-20 text-neutral-400">Sélectionnez vos paramètres pour voir nos suggestions de consommables.</p>
            </div>
            <div id="total-estimation" class="mt-8 pt-6 border-t border-neutral-100 text-right hidden">
              <span class="text-xs uppercase text-neutral-400 block mb-1">Estimation budget consommables HT</span>
              <span id="total-price" class="text-3xl font-heading text-primary">0,00 €</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- NOTRE ENGAGEMENT -->
  <section class="py-24 bg-bg-alt">
    <div class="container mx-auto px-6">
      <div class="flex flex-col lg:flex-row-reverse gap-16 items-center">
        <div class="lg:w-1/2">
          <div class="relative group">
            <img src="https://images.pexels.com/photos/8657297/pexels-photo-8657297.jpeg?auto=compress&cs=tinysrgb&dpr=2&h=650&w=940" alt="Équipements de laboratoire" class="w-full rounded-sm grayscale group-hover:grayscale-0 transition-all duration-700" loading="lazy" />
            <div class="absolute inset-0 border-[1px] border-secondary translate-x-4 translate-y-4 -z-10"></div>
          </div>
        </div>
        <div class="lg:w-1/2">
          <h2 class="font-heading text-5xl text-primary mb-8 reveal-on-scroll italic">Un approvisionnement fiable et rigoureux</h2>
          <p class="text-lg leading-relaxed text-neutral-700 mb-8">
            La continuité de vos activités de recherche dépend de la fiabilité de votre chaîne d'approvisionnement. Nous sélectionnons nos fournisseurs avec exigence pour vous garantir des produits conformes, traçables et disponibles dans les meilleurs délais.
          </p>
          <div class="grid grid-cols-2 gap-8 mb-10">
            <div>
              <h4 class="font-bold text-primary mb-2 uppercase text-xs tracking-widest">Traçabilité</h4>
              <p class="text-sm text-neutral-500">Certificats de conformité et fiches de données de sécurité disponibles pour chaque produit.</p>
            </div>
            <div>
              <h4 class="font-bold text-primary mb-2 uppercase text-xs tracking-widest">Réactivité</h4>
              <p class="text-sm text-neutral-500">Livraison rapide sur les références courantes pour éviter toute rupture en cours de protocole.</p>
            </div>
          </div>
          <a href="/contact-devis" class="inline-flex items-center gap-3 text-secondary font-bold group">
            <span class="border-b-2 border-secondary">Demander un devis</span>
            <svg class="w-5 h-5 group-hover:translate-x-2 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- PARTENARIATS -->
  <section class="py-24 bg-white">
    <div class="container mx-auto px-6">
      <div class="flex justify-between items-end mb-16">
        <div class="max-w-xl">
          <h2 class="font-heading text-5xl text-primary mb-6 reveal-on-scroll">Partenariats de confiance</h2>
          <p class="text-neutral-600">Nous avons sélectionné les marques les plus fiables du marché mondial pour garantir la répétabilité de vos résultats.</p>
        </div>
        <div class="hidden lg:block">
          <span class="text-secondary font-heading text-6xl opacity-20 italic font-bold">Analytic Lab</span>
        </div>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-12 opacity-50 grayscale hover:grayscale-0 transition-all duration-500">
        <div class="flex items-center justify-center p-8 border border-neutral-100 text-neutral-400 font-bold tracking-tighter text-xl">DURAN WHEATON</div>
        <div class="flex items-center justify-center p-8 border border-neutral-100 text-neutral-400 font-bold tracking-tighter text-xl">BRAND GMBH</div>
        <div class="flex items-center justify-center p-8 border border-neutral-100 text-neutral-400 font-bold tracking-tighter text-xl">IKA GERMANY</div>
        <div class="flex items-center justify-center p-8 border border-neutral-100 text-neutral-400 font-bold tracking-tighter text-xl">METTLER TOLEDO</div>
        <div class="flex items-center justify-center p-8 border border-neutral-100 text-neutral-400 font-bold tracking-tighter text-xl">SIGMA ALDRICH</div>
        <div class="flex items-center justify-center p-8 border border-neutral-100 text-neutral-400 font-bold tracking-tighter text-xl">EPPENDORF</div>
        <div class="flex items-center justify-center p-8 border border-neutral-100 text-neutral-400 font-bold tracking-tighter text-xl">SARTORIUS</div>
        <div class="flex items-center justify-center p-8 border border-neutral-100 text-neutral-400 font-bold tracking-tighter text-xl">CORNING</div>
      </div>
    </div>
  </section>

  <!-- LOGISTIQUE & SERVICES -->
  <section class="py-24 bg-primary">
    <div class="container mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-0">
        <div class="bg-white p-12 reveal-on-scroll">
          <h3 class="font-heading text-3xl text-primary mb-6 italic">Logistique agile</h3>
          <p class="text-neutral-600 mb-8 text-sm leading-relaxed">
            Grâce à notre centre logistique situé en Ile-de-France, nous stockons plus de 15 000 références prêtes à l'expédition. Nous comprenons l'urgence d'une rupture de stock en plein protocole de recherche.
          </p>
          <ul class="space-y-4 text-xs font-bold text-primary">
            <li class="flex items-center gap-3">
              <svg class="w-5 h-5 text-secondary" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg> LIVRAISON 24/48H SUR ARTICLES EN STOCK
            </li>
            <li class="flex items-center gap-3">
              <svg class="w-5 h-5 text-secondary" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg> IMPORT FICHIERS CSV POUR ERP
            </li>
            <li class="flex items-center gap-3">
              <svg class="w-5 h-5 text-secondary" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg> GESTION DES DÉCHETS CHIMIQUES
