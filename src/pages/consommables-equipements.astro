  />

</BaseLayout>

<script>
  const slider = document.getElementById('bench-count') as HTMLInputElement;
  const benchVal = document.getElementById('bench-val');
  const calcBtn = document.getElementById('calc-btn');

  slider?.addEventListener('input', () => {
    const val = slider.value;
    if (benchVal) benchVal.innerText = `${val} paillasse${parseInt(val) > 1 ? 's' : ''}`;
  });

  function calculateStock() {
    const type = (document.getElementById('lab-type') as HTMLSelectElement).value;
    const count = parseInt((document.getElementById('bench-count') as HTMLInputElement).value);
    const resultBox = document.getElementById('results-content');
    const priceBox = document.getElementById('total-estimation');
    const totalPrice = document.getElementById('total-price');

    let items: string[] = [];
    let basePrice = 0;

    if (type === 'chimie') {
      items = [
        `Pack de ${count*5} ballons rodés ST 29/32 (250ml/500ml)`,
        `Set de ${count*2} colonnes à distiller Vigreux sur mesure`,
        `Stock de solvants : 40L Acétone, 20L Éthanol pur`,
        `${count*20} Filtres plissés et entonnoirs Büchner`,
        `Kit de sécurité : ${count*4} paires de gants nitrile et douches oculaires`
      ];
      basePrice = count * 1450;
    } else if (type === 'bio') {
      items = [
        `${count*500} Boites de Pétri stériles et anses d'inoculation`,
        `Pack de ${count*2} micropipettes multicanaux`,
        `100L de milieux de culture déshydratés`,
        `${count*10} Flacons de stockage gradués autoclavables`,
        `Système de filtration stérile sous vide`
      ];
      basePrice = count * 1820;
    } else {
      items = [
        `Verrerie de base : Béchers (x${count*10}) et Éprouvettes`,
        `Agitateurs magnétiques (x${count})`,
        `Set de balances de précision`,
        `Produits de nettoyage spécialisés (Type RBS)`,
        `Stock de tubes à essai et portoirs`
      ];
      basePrice = count * 950;
    }

    if (resultBox) {
      resultBox.innerHTML = '<ul class="space-y-3">' + items.map(i => `<li class="flex items-start gap-2"><span class="text-secondary mt-1">&#9657;</span> ${i}</li>`).join('') + '</ul>';
    }
    if (priceBox) priceBox.classList.remove('hidden');
    if (totalPrice) totalPrice.innerText = new Intl.NumberFormat('fr-FR', { style: 'currency', currency: 'EUR' }).format(basePrice);
  }

  calcBtn?.addEventListener('click', calculateStock);
</script>
