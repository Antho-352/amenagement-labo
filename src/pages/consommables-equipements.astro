  <!-- FAQ -->
  <FaqAccordion items={faqItems} />

  <!-- CTA FINAL -->
  <CtaBanner
    title={cta?.ctaTitle ?? "Prêt à équiper votre excellence ?"}
    description={cta?.ctaDescription ?? "Contactez nos experts pour obtenir un devis personnalisé ou une étude de vos besoins spécifiques."}
    ctas={cta?.ctaButtons ?? [
      { label: 'Demander un Devis Rapide', href: '/contact-devis' },
      { label: "Voir l'Aménagement Global", href: '/conception-laboratoires', variant: 'outline' },
    ]}
